{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mezame",
  "version": "0.1.0",
  "identifier": "com.gabdcouto.mezame",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "backgroundColor": "#1e1e1e",
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/gabrieldocoutos/mezame/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzNDJBODYzM0JEODI0RDgKUldUWUpOZzdZNmhDbzByeWFnVEoyRG96a2cwamU4NlZ2WUtqQjdxSnVMTmdyYkEvMzk2VisyS2wK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
